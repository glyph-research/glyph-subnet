# Copy to .env and fill in. .env is gitignored; .env.example is committed.

# Chutes (SN64) cpk_ invocation key used by the validator's ChutesRunner.
# Create one with: chutes keys create --name glyph-validator --admin
CHUTES_API_KEY=cpk_...

# Optional: the Chutes account that deployed the eval chutes. Used to build the default
# compress/decompress chute URLs and as the build/deploy username. Defaults to "glyph"; set
# if you deployed under a different account.
# GLYPH_CHUTE_USERNAME=glyph

# Optional: override the deployed chute base URLs outright (take precedence over
# GLYPH_CHUTE_USERNAME). Compress and decompress are SEPARATE chutes; point every validator at
# the same two deployed chutes.
# GLYPH_COMPRESS_CHUTE_URL=https://<account>-glyph-compressor.chutes.ai
# GLYPH_DECOMPRESS_CHUTE_URL=https://<account>-glyph-decompressor.chutes.ai
