# Copy to .env and fill in. .env is gitignored; .env.example is committed.

# Chutes (SN64) cpk_ invocation key used by the validator's ChutesRunner.
# Create one with: chutes keys create --name glyph-validator --admin
CHUTES_API_KEY=cpk_...

# Optional: the Chutes account that deployed the glyph-runner chute. Used to build the default
# chute URL and as the build/deploy username. Defaults to "glyph"; set if you deployed under a
# different account.
# GLYPH_CHUTE_USERNAME=glyph

# Optional: override the deployed glyph-runner chute base URL outright (takes precedence over
# GLYPH_CHUTE_USERNAME). Point every validator at the same deployed chute.
# GLYPH_CHUTE_URL=https://<account>-glyph-runner.chutes.ai
