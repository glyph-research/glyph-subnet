# Copy to .env and fill in. .env is gitignored; .env.example_miners is committed.
# This is the miner-side counterpart to .env.example (which is Chutes/validator-oriented).

# HuggingFace token, used by `glyph-miner publish` to upload your codec artifact and by
# `glyph-miner commit`/`check` to resolve/download a repo@rev. Create one at
# https://huggingface.co/settings/tokens (write access needed only for `publish`).
HF_TOKEN=hf_...

# Wallet name/hotkey, netuid, and chain endpoint are NOT read from .env -- every
# glyph-miner subcommand (register/commit/check) takes them as CLI flags with defaults,
# e.g.:
#   glyph-miner commit --netuid 117 --network finney \
#     --wallet-name your-wallet --hotkey-name your-hotkey \
#     --model-repo your-user/your-codec
# See docs/MINING.md for the full command sequence.
